             style="-fx-text-fill: #b388ff;" wrapText="true">
         <font>
            <Font name="Segoe UI Semibold" size="15.0" />
         </font>
      </Label>
      <Label fx:id="lblMessage" layoutX="90.0" layoutY="50.0" text="Message:"
