<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.collections.*?>
<?import javafx.scene.*?>
<?import javafx.scene.text.*?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import java.lang.String?>

<BorderPane fx:id="borderPane" maxHeight="620.0" maxWidth="1040.0" prefHeight="620.0" prefWidth="1040.0"
            stylesheets="@../styles/ChatViewStyle.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.client.chatwindow.ChatController">
   <center>
      <VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
            style="-fx-background-color: #1a1a2e;">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="40.0" 
                  style="-fx-background-color: rgba(124,77,255,0.1); -fx-border-color: transparent transparent rgba(124,77,255,0.2) transparent; -fx-border-width: 0 0 1 0;">
               <children>
                  <Label fx:id="chatHeaderLabel" text="Chat Global" textFill="#b388ff">
                     <font>
                        <Font name="Segoe UI Semibold" size="14.0" />
                     </font>
                     <padding>
                        <Insets left="15.0" />
                     </padding>
                  </Label>
               </children>
            </HBox>
            <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER"
                        maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                        pannable="true" prefHeight="496.0" vbarPolicy="AS_NEEDED"
                        vmin="1.0" vvalue="1.0" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: #1a1a2e; -fx-background: #1a1a2e;">
               <content>
                  <ListView fx:id="chatPane" maxHeight="1.7976931348623157E308"
                            maxWidth="1.7976931348623157E308" prefHeight="200.0" prefWidth="200.0"
                            style="-fx-background-color: #1a1a2e;" />
               </content>
            </ScrollPane>
            <HBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                  minHeight="-Infinity" minWidth="100.0" VBox.vgrow="NEVER"
                  style="-fx-background-color: rgba(255,255,255,0.03); -fx-border-color: rgba(124,77,255,0.15) transparent transparent transparent; -fx-border-width: 1 0 0 0;">
               <children>
                  <TextArea fx:id="messageBox" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                            minHeight="-Infinity" minWidth="100.0" nodeOrientation="LEFT_TO_RIGHT"
                            prefHeight="16.0" prefWidth="698.0"
                            promptText="Écrire un message..." scaleShape="false" HBox.hgrow="ALWAYS">
                     <font>
                        <Font name="Segoe UI" size="14.0" />
                     </font>
                  </TextArea>
                  <Button fx:id="buttonSend" alignment="CENTER" maxHeight="1.7976931348623157E308"
                          maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity"
                          mnemonicParsing="false" onAction="#sendButtonAction"
                          prefHeight="43.0" prefWidth="140.0" scaleShape="false"
                          text="Envoyer" textAlignment="CENTER" HBox.hgrow="NEVER">
                     <font>
                        <Font name="Segoe UI Semibold" size="14.0" />
                     </font>
                  </Button>
                  <Button fx:id="recordBtn" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                          mnemonicParsing="false" onMousePressed="#recordVoiceMessage">
                     <graphic>
                        <ImageView fx:id="microphoneImageView" fitHeight="24.0" fitWidth="24.0"
                                   pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../images/microphone.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
               </children>
            </HBox>
         </children>
      </VBox>
   </center>
   <left>
      <VBox maxHeight="1.7976931348623157E308" BorderPane.alignment="CENTER"
            style="-fx-background-color: #16213e;">
         <children>
            <HBox fx:id="onlineUsersHbox" minHeight="-Infinity" minWidth="-Infinity"
                  prefHeight="50.0" prefWidth="217.0"
                  stylesheets="@../styles/ListViewStyle.css">
               <children>
                  <Label prefHeight="50.0" prefWidth="140.0" text="👥 Utilisateurs :" textAlignment="CENTER" textFill="#b388ff">
                     <font>
                        <Font name="Segoe UI Semibold" size="14.0" />
                     </font>
                     <padding>
                        <Insets left="12.0" />
                     </padding>
                  </Label>
                  <Label fx:id="onlineCountLabel" prefHeight="48.0" prefWidth="60.0" text="0" textFill="#7c4dff">
                     <font>
                        <Font name="Segoe UI Bold" size="16.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
            <ListView fx:id="userList" focusTraversable="false" maxHeight="1.7976931348623157E308"
                      prefHeight="495.0" prefWidth="217.0"
                      style="-fx-background-color: #16213e; -fx-border-color: transparent;"
                      stylesheets="@../styles/ListViewStyle.css">
            </ListView>
         </children>
      </VBox>
   </left>
   <top>
      <BorderPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                  style="-fx-background-color: linear-gradient(to right, #16213e, #0f3460); -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 10, 0, 0, 3);"
                  BorderPane.alignment="CENTER">
         <center>
            <ImageView fitHeight="60.0" fitWidth="300.0" pickOnBounds="true" preserveRatio="true"
                       BorderPane.alignment="CENTER">
               <image>
                  <Image url="@../images/fxchat.png" />
               </image>
               <BorderPane.margin>
                  <Insets right="100.0" />
               </BorderPane.margin>
            </ImageView>
         </center>
         <right>
            <HBox alignment="CENTER_RIGHT" prefHeight="80.0" spacing="15" stylesheets="@../styles/ButtonStyle.css"
                  BorderPane.alignment="CENTER">
               <children>
                  <ImageView fitHeight="23.0" fitWidth="30.0" pickOnBounds="true" preserveRatio="true"
                             styleClass="button" opacity="0.8">
                     <image><Image url="@../images/settings.png" /></image>
                     <cursor><Cursor fx:constant="HAND" /></cursor>
                  </ImageView>
                  <ImageView fitHeight="22.0" fitWidth="21.0" onMousePressed="#closeApplication"
                             pickOnBounds="true" preserveRatio="true" styleClass="button" opacity="0.8">
                     <image><Image url="@../images/close_normal.png" /></image>
                     <cursor><Cursor fx:constant="HAND" /></cursor>
                  </ImageView>
               </children>
               <padding><Insets right="20"/></padding>
            </HBox>
         </right>
         <left>
            <HBox prefWidth="259.0" alignment="CENTER_LEFT" BorderPane.alignment="CENTER">
               <children>
                  <ImageView fx:id="userImageView" fitHeight="50.0" fitWidth="50.0" pickOnBounds="true"
                             preserveRatio="true">
                     <image><Image url="@../images/default.png" /></image>
                     <HBox.margin><Insets left="15"/></HBox.margin>
                  </ImageView>
                  <VBox alignment="CENTER_LEFT" spacing="2">
                     <HBox.margin><Insets left="15"/></HBox.margin>
                     <children>
                        <Label fx:id="usernameLabel" text="Utilisateur" textFill="#b388ff">
                           <font><Font name="Segoe UI Semibold" size="15.0" /></font>
                        </Label>
                        <ComboBox fx:id="statusComboBox" prefHeight="25.0" prefWidth="101.0"
                                  promptText="En ligne" stylesheets="@../styles/ComboBox.css">
                           <items>
                              <FXCollections fx:factory="observableArrayList">
                                 <String fx:value="Online" /><String fx:value="Away" /><String fx:value="Busy" />
                              </FXCollections>
                           </items>
                        </ComboBox>
                     </children>
                  </VBox>
               </children>
               <padding><Insets bottom="10" top="10"/></padding>
            </HBox>
         </left>
      </BorderPane>
   </top>
</BorderPane>
